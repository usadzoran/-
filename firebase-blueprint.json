{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a user (student, teacher, or admin)",
      "type": "object",
      "properties": {
        "auth_id": { "type": "string" },
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "account_status": { "type": "string", "enum": ["active", "pending", "suspended"] },
        "profile_image": { "type": "string" },
        "bio": { "type": "string" },
        "rating": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["auth_id", "first_name", "last_name", "role", "account_status", "created_at"]
    },
    "Post": {
      "title": "Post",
      "description": "A post shared by a teacher or student",
      "type": "object",
      "properties": {
        "author_id": { "type": "string" },
        "content": { "type": "string" },
        "image_url": { "type": "string" },
        "video_url": { "type": "string" },
        "likes_count": { "type": "number" },
        "comments_count": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["author_id", "content", "created_at"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post",
      "type": "object",
      "properties": {
        "post_id": { "type": "string" },
        "author_id": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["post_id", "author_id", "content", "created_at"]
    },
    "LiveClass": {
      "title": "Live Class",
      "description": "A live interactive session",
      "type": "object",
      "properties": {
        "teacher_id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "description": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["upcoming", "live", "ended"] },
        "meeting_link": { "type": "string" },
        "max_students": { "type": "number" },
        "current_students": { "type": "number" }
      },
      "required": ["teacher_id", "title", "subject", "start_time", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "A private message between users",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string" },
        "receiver_id": { "type": "string" },
        "content": { "type": "string" },
        "is_read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["sender_id", "receiver_id", "content", "created_at"]
    },
    "LessonFile": {
      "title": "Lesson File",
      "description": "Educational files uploaded by teachers",
      "type": "object",
      "properties": {
        "teacher_id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "file_url": { "type": "string" },
        "file_type": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["teacher_id", "title", "subject", "file_url", "file_type", "created_at"]
    },
    "ExplainVideo": {
      "title": "Explain Video",
      "description": "Recorded explanation videos",
      "type": "object",
      "properties": {
        "teacher_id": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "video_url": { "type": "string" },
        "thumbnail_url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["teacher_id", "title", "subject", "video_url", "created_at"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Student subscription to a teacher's subject",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "teacher_id": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["student_id", "teacher_id", "subject", "status", "created_at"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Logs of user actions",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles" },
    "/posts/{postId}": { "schema": "Post", "description": "Community posts" },
    "/posts/{postId}/comments/{commentId}": { "schema": "Comment", "description": "Comments on posts" },
    "/live_classes/{classId}": { "schema": "LiveClass", "description": "Live interactive classes" },
    "/messages/{messageId}": { "schema": "Message", "description": "Private messages" },
    "/lesson_files/{fileId}": { "schema": "LessonFile", "description": "Educational PDF/Files" },
    "/explain_videos/{videoId}": { "schema": "ExplainVideo", "description": "Explanation videos" },
    "/subscriptions/{subId}": { "schema": "Subscription", "description": "Student-Teacher subscriptions" },
    "/activity_logs/{logId}": { "schema": "ActivityLog", "description": "System activity logs" }
  }
}
